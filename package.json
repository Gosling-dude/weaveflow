{
  "name": "weaveflow",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @weaveflow/web",
    "build": "npm run build --workspace @weaveflow/web",
    "lint": "npm run lint --workspace @weaveflow/web",
    "typecheck": "npm run typecheck --workspace @weaveflow/web",
    "prisma:generate": "npm run prisma:generate --workspace @weaveflow/web",
    "prisma:migrate": "npm run prisma:migrate --workspace @weaveflow/web",
    "prisma:seed": "npm run prisma:seed --workspace @weaveflow/web"
  }
}